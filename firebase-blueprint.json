{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "lastLogin": { "type": "number" }
      }
    },
    "BlogArticle": {
      "title": "BlogArticle",
      "description": "A blog article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" },
        "authorId": { "type": "string" }
      }
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a blog article",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Channel": {
      "title": "Channel",
      "description": "A chat channel",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" },
        "ownerId": { "type": "string" }
      }
    },
    "Post": {
      "title": "Post",
      "description": "A newsfeed post",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Note": {
      "title": "Note",
      "description": "A note",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "ownerId": { "type": "string" },
        "keepId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "A task in a task list",
      "type": "object",
      "properties": {
        "listId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "assigneeId": { "type": "string" },
        "updatedAt": { "type": "number" }
      }
    },
    "TaskList": {
      "title": "TaskList",
      "description": "A list of tasks",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Event": {
      "title": "Event",
      "description": "A calendar event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Page": {
      "title": "Page",
      "description": "A website page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "A configuration setting",
      "type": "object",
      "properties": {}
    },
    "KanbanTask": {
      "title": "KanbanTask",
      "description": "A kanban task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "A user notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users collection"
    },
    "/blogArticles/{articleId}": {
      "schema": "BlogArticle",
      "description": "Blog articles"
    },
    "/blogArticles/{articleId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a blog article"
    },
    "/channels/{channelId}": {
      "schema": "Channel",
      "description": "Chat channels"
    },
    "/channels/{channelId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a chat channel"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Newsfeed posts"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks"
    },
    "/taskLists/{listId}": {
      "schema": "TaskList",
      "description": "Task lists"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Calendar events"
    },
    "/pages/{pageId}": {
      "schema": "Page",
      "description": "Website pages"
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Global and email settings"
    },
    "/kanban_tasks/{kanbanTaskId}": {
      "schema": "KanbanTask",
      "description": "Kanban tasks"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
